@page "/async-misuse-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.AsyncMisuseChallenge
@inject AsyncMisuseChallengeRunner Runner

<PageTitle>Async Misuse Challenge</PageTitle>

<header class="challenge-header">
    <div class="challenge-header-content">
        <h1 data-icon="⏱️">Async Misuse Challenge</h1>
        <p class="lead">
            Fix async anti-patterns that cause thread pool starvation, deadlocks, and unresponsive applications.
            Start with <code>PracticeAsyncMisuseService.cs</code> and refactor until it matches <code>RefactoredAsyncMisuseService.cs</code>.
        </p>
    </div>
</header>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="itemCount">Items to Process</label>
        <select id="itemCount" class="form-select" @bind="_itemCount">
            <option value="10">10 Items</option>
            <option value="50">50 Items</option>
            <option value="100">100 Items (Recommended)</option>
        </select>
        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-info">
        <p class="challenge-info-title">Async anti-patterns to find and fix</p>
        <ul>
            <li><strong>Sync-over-async:</strong> Using <code>.Result</code> or <code>.Wait()</code> blocks threads and can cause deadlocks.</li>
            <li><strong>Fire-and-forget:</strong> <code>async void</code> or unawaited Tasks hide exceptions and crash apps.</li>
            <li><strong>Missing cancellation:</strong> No <code>CancellationToken</code> means operations can't be gracefully stopped.</li>
            <li><strong>Thread pool starvation:</strong> Blocking calls exhaust available threads, queuing new work.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="challenge-results">
        <h2>Results for @_result.ItemCount Items</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Processed:</strong> @_result.Bad.ProcessedCount</p>
                <p><strong>Worker threads before:</strong> @_result.Bad.WorkerThreadsBefore</p>
                <p><strong>Worker threads after:</strong> @_result.Bad.WorkerThreadsAfter</p>
                <p><strong>Threads consumed:</strong> @_result.Bad.ThreadsUsed</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Processed:</strong> @_result.Practice.ProcessedCount</p>
                <p><strong>Worker threads before:</strong> @_result.Practice.WorkerThreadsBefore</p>
                <p><strong>Worker threads after:</strong> @_result.Practice.WorkerThreadsAfter</p>
                <p><strong>Threads consumed:</strong> @_result.Practice.ThreadsUsed</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Processed:</strong> @_result.Refactored.ProcessedCount</p>
                <p><strong>Worker threads before:</strong> @_result.Refactored.WorkerThreadsBefore</p>
                <p><strong>Worker threads after:</strong> @_result.Refactored.WorkerThreadsAfter</p>
                <p><strong>Threads consumed:</strong> @_result.Refactored.ThreadsUsed</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>

        <div class="challenge-summary">
            <p><strong>Practice speedup:</strong> @FormatSpeedup(_result.Bad, _result.Practice)</p>
            <p><strong>AI refactored speedup:</strong> @FormatSpeedup(_result.Bad, _result.Refactored)</p>
        </div>
    </section>
}

@code {
    private int _itemCount = 100;
    private bool _isRunning;
    private string? _error;
    private AsyncChallengeComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_itemCount);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static string FormatMilliseconds(double value) => $"{value:N1} ms";

    private static string FormatSpeedup(AsyncScenarioRunResult baseline, AsyncScenarioRunResult candidate)
    {
        if (candidate.ElapsedMilliseconds <= 0.1) return "n/a";
        var speedup = baseline.ElapsedMilliseconds / candidate.ElapsedMilliseconds;
        return $"{speedup:N1}x faster";
    }
}
