@page "/allocation-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.AllocationChallenge
@inject AllocationChallengeRunner Runner

<PageTitle>Allocation & GC Challenge</PageTitle>

<h1>Allocation & GC Lab</h1>

<p class="lead">
    Practice spotting and fixing heavy memory allocations in hot paths like string concatenation (`+=`), boxing, and unnecessary `LINQ`.
    Start with <code>Features/AllocationChallenge/PracticeAllocationService.cs</code>, which starts from the same
    implementation as <code>Features/AllocationChallenge/BadAllocationService.cs</code>, then refactor it until it behaves
    like <code>Features/AllocationChallenge/RefactoredAllocationService.cs</code>.
</p>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="itemCount">Items to Process</label>
        <select id="itemCount" class="form-select" @bind="_itemCount">
            <option value="10000">10,000 Items</option>
            <option value="50000">50,000 Items</option>
            <option value="100000">100,000 Items (Recommended)</option>
        </select>
        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-smells">
        <p class="mb-1 fw-semibold">What to find in the bad version:</p>
        <ul class="mb-0">
            <li><strong>String Churn:</strong> Using <code>+=</code> in loops creates thousands of abandoned strings that trigger garbage collection.</li>
            <li><strong>Boxing:</strong> Storing value types (like <code>int</code>) in untyped object collections allocates memory on the heap.</li>
            <li><strong>LINQ in Hot Paths:</strong> <code>.Where</code> and <code>.Select</code> inside extreme hot paths create hidden enumerator and closure allocations.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="mt-4">
        <h2>Run Result for @(_result.ItemCount.ToString("N0")) Items</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad @(_result.Bad.AllocatedMegabytes > 10 ? "border-danger" : "")">
                <h3>@_result.Bad.Label</h3>
                <p>
                    <strong>Memory Allocated:</strong> 
                    <span class="@(_result.Bad.AllocatedMegabytes > 10 ? "text-danger fw-bold" : "")">
                        @(_result.Bad.AllocatedMegabytes.ToString("N1")) MB
                    </span>
                </p>
                <p><strong>Gen 0 Collections:</strong> @_result.Bad.Gen0Collections</p>
                <p><strong>Gen 1 Collections:</strong> @_result.Bad.Gen1Collections</p>
                <p><strong>Gen 2 Collections:</strong> @_result.Bad.Gen2Collections</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-practice @(_result.Practice.AllocatedMegabytes > 10 ? "border-danger" : "")">
                <h3>@_result.Practice.Label</h3>
                <p>
                    <strong>Memory Allocated:</strong> 
                    <span class="@(_result.Practice.AllocatedMegabytes > 10 ? "text-danger fw-bold" : "")">
                        @(_result.Practice.AllocatedMegabytes.ToString("N1")) MB
                    </span>
                </p>
                <p><strong>Gen 0 Collections:</strong> @_result.Practice.Gen0Collections</p>
                <p><strong>Gen 1 Collections:</strong> @_result.Practice.Gen1Collections</p>
                <p><strong>Gen 2 Collections:</strong> @_result.Practice.Gen2Collections</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good @(_result.Refactored.AllocatedMegabytes < 1 ? "border-success" : "")">
                <h3>@_result.Refactored.Label</h3>
                <p>
                    <strong>Memory Allocated:</strong> 
                    <span class="@(_result.Refactored.AllocatedMegabytes < 1 ? "text-success fw-bold" : "")">
                        @(_result.Refactored.AllocatedMegabytes.ToString("N1")) MB
                    </span>
                </p>
                <p><strong>Gen 0 Collections:</strong> @_result.Refactored.Gen0Collections</p>
                <p><strong>Gen 1 Collections:</strong> @_result.Refactored.Gen1Collections</p>
                <p><strong>Gen 2 Collections:</strong> @_result.Refactored.Gen2Collections</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>
    </section>
}

@code {
    private int _itemCount = 100000;
    private bool _isRunning;
    private string? _error;
    private AllocationChallengeComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Bad vs Practice vs Refactored";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_itemCount);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static string FormatMilliseconds(double value)
    {
        return $"{value:N1} ms";
    }
}
