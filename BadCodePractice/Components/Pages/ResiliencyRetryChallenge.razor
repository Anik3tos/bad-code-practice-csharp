@page "/resiliency-retry-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.ResiliencyRetryChallenge
@inject ResiliencyRetryChallengeRunner Runner

<PageTitle>Resiliency & Retry Challenge</PageTitle>

<header class="challenge-header">
    <div class="challenge-header-content">
        <h1 data-icon="🛡️">Resiliency & Retry Challenge</h1>
        <p class="lead">
            Implement proper retry strategies with backoff, jitter, and circuit breaking to handle transient failures gracefully.
            Start with <code>PracticeResiliencyRetryService.cs</code> and refactor until it matches <code>RefactoredResiliencyRetryService.cs</code>.
        </p>
    </div>
</header>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="totalRequests">Total requests</label>
        <input id="totalRequests" type="number" class="form-control" min="100" max="5000" @bind="_totalRequests" />

        <label for="concurrency" class="mt-3">Concurrent workers</label>
        <input id="concurrency" type="number" class="form-control" min="4" max="128" @bind="_concurrentWorkers" />

        <label for="faultPercent" class="mt-3">Fault injection (%)</label>
        <input id="faultPercent" type="number" class="form-control" min="0" max="95" @bind="_faultPercent" />

        <label for="slowPercent" class="mt-3">Slow responses (%)</label>
        <input id="slowPercent" type="number" class="form-control" min="0" max="95" @bind="_slowPercent" />

        <label for="slowLatencyMs" class="mt-3">Slow latency (ms)</label>
        <input id="slowLatencyMs" type="number" class="form-control" min="100" max="1500" @bind="_slowLatencyMs" />

        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-info">
        <p class="challenge-info-title">Resiliency anti-patterns to fix</p>
        <ul>
            <li><strong>Blind retries:</strong> Retrying without checking if the error is transient.</li>
            <li><strong>No backoff:</strong> Immediate retries can overwhelm a struggling service.</li>
            <li><strong>Missing jitter:</strong> Synchronized retries from multiple clients cause thundering herd.</li>
            <li><strong>No circuit breaker:</strong> Continued calls to a failed service waste resources.</li>
            <li><strong>No timeout:</strong> Hanging requests consume threads indefinitely.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="challenge-results">
        <h2>Results</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Success rate:</strong> @FormatPercent(_result.Bad.SuccessRatePercent)</p>
                <p><strong>P95 latency:</strong> @FormatMilliseconds(_result.Bad.P95LatencyMilliseconds)</p>
                <p><strong>Downstream calls:</strong> @_result.Bad.DownstreamCallCount.ToString("N0")</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Success rate:</strong> @FormatPercent(_result.Practice.SuccessRatePercent)</p>
                <p><strong>P95 latency:</strong> @FormatMilliseconds(_result.Practice.P95LatencyMilliseconds)</p>
                <p><strong>Downstream calls:</strong> @_result.Practice.DownstreamCallCount.ToString("N0")</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Success rate:</strong> @FormatPercent(_result.Refactored.SuccessRatePercent)</p>
                <p><strong>P95 latency:</strong> @FormatMilliseconds(_result.Refactored.P95LatencyMilliseconds)</p>
                <p><strong>Downstream calls:</strong> @_result.Refactored.DownstreamCallCount.ToString("N0")</p>
            </article>
        </div>

        <div class="challenge-summary">
            <p><strong>Practice success improvement:</strong> @FormatSuccessImprovement(_result.Bad, _result.Practice)</p>
            <p><strong>Practice P95 latency improvement:</strong> @FormatTailLatencyImprovement(_result.Bad, _result.Practice)</p>
            <p><strong>Practice downstream call reduction:</strong> @FormatCallReduction(_result.Bad, _result.Practice)</p>
            <p><strong>AI refactored success improvement:</strong> @FormatSuccessImprovement(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored P95 latency improvement:</strong> @FormatTailLatencyImprovement(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored downstream call reduction:</strong> @FormatCallReduction(_result.Bad, _result.Refactored)</p>
        </div>

        <div class="challenge-table">
            <h3>Detailed Metrics</h3>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Implementation</th>
                        <th>Successful</th>
                        <th>Total</th>
                        <th>Success rate</th>
                        <th>P95 latency</th>
                        <th>Downstream calls</th>
                        <th>Elapsed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in GetRows(_result))
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td>@row.SuccessfulRequests.ToString("N0")</td>
                            <td>@row.TotalRequests.ToString("N0")</td>
                            <td>@FormatPercent(row.SuccessRatePercent)</td>
                            <td>@FormatMilliseconds(row.P95LatencyMilliseconds)</td>
                            <td>@row.DownstreamCallCount.ToString("N0")</td>
                            <td>@FormatMilliseconds(row.ElapsedMilliseconds)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private int _totalRequests = 1200;
    private int _concurrentWorkers = 32;
    private int _faultPercent = 35;
    private int _slowPercent = 20;
    private int _slowLatencyMs = 700;
    private bool _isRunning;
    private string? _error;
    private ResiliencyRetryComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_totalRequests, _concurrentWorkers, _faultPercent, _slowPercent, _slowLatencyMs);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static IEnumerable<ResiliencyScenarioResult> GetRows(ResiliencyRetryComparisonResult result)
    {
        yield return result.Bad;
        yield return result.Practice;
        yield return result.Refactored;
    }

    private static string FormatPercent(double value) => $"{value:N1}%";
    private static string FormatMilliseconds(double value) => $"{value:N1} ms";

    private static string FormatSuccessImprovement(ResiliencyScenarioResult baseline, ResiliencyScenarioResult candidate)
    {
        var delta = candidate.SuccessRatePercent - baseline.SuccessRatePercent;
        return $"{delta:N1} percentage points";
    }

    private static string FormatTailLatencyImprovement(ResiliencyScenarioResult baseline, ResiliencyScenarioResult candidate)
    {
        if (candidate.P95LatencyMilliseconds <= 0.1) return "n/a";
        var improvement = baseline.P95LatencyMilliseconds / candidate.P95LatencyMilliseconds;
        return $"{improvement:N1}x lower";
    }

    private static string FormatCallReduction(ResiliencyScenarioResult baseline, ResiliencyScenarioResult candidate)
    {
        if (baseline.DownstreamCallCount <= 0) return "n/a";
        var reduction = 100 - (candidate.DownstreamCallCount * 100.0 / baseline.DownstreamCallCount);
        return $"{reduction:N1}% fewer calls";
    }
}
