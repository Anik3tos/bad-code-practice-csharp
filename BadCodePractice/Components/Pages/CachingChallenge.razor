@page "/caching-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.CachingChallenge
@inject CachingChallengeRunner Runner

<PageTitle>Caching Challenge</PageTitle>

<h1>Caching Challenge</h1>

<p class="lead">
    Start with <code>Features/CachingChallenge/PracticeCachingChallengeService.cs</code>.
    It starts with the same bad logic as <code>BadCachingChallengeService.cs</code>.
</p>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="requests">Total requests</label>
        <input id="requests" type="number" class="form-control" min="100" max="5000" @bind="_totalRequests" />

        <label for="workers" class="mt-3">Concurrent workers</label>
        <input id="workers" type="number" class="form-control" min="4" max="128" @bind="_concurrentWorkers" />

        <label for="keyspace" class="mt-3">Key space</label>
        <input id="keyspace" type="number" class="form-control" min="5" max="500" @bind="_keySpace" />

        <label for="payload" class="mt-3">Payload (KB per entry)</label>
        <input id="payload" type="number" class="form-control" min="4" max="256" @bind="_payloadKilobytes" />

        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-smells">
        <p class="mb-1 fw-semibold">What to fix in the cache implementation:</p>
        <ul class="mb-0">
            <li>Unbounded cache growth</li>
            <li>No TTL or eviction policy</li>
            <li>Cache stampede on hot keys</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="mt-4">
        <h2>Run Results</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Retained memory:</strong> @FormatBytes(_result.Bad.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Bad.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Retained memory:</strong> @FormatBytes(_result.Practice.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Practice.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Retained memory:</strong> @FormatBytes(_result.Refactored.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Refactored.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>

        <div class="challenge-summary mt-3">
            <p class="mb-1">
                <strong>Memory retained reduction:</strong> @FormatMemoryReduction(_result)
            </p>
            <p class="mb-1">
                <strong>Hit ratio improvement:</strong> @FormatHitRatioImprovement(_result)
            </p>
            <p class="mb-0">
                <strong>Response time speedup:</strong> @FormatSpeedup(_result)
            </p>
        </div>

        <h3 class="mt-4">Detailed Metrics</h3>
        <table class="table table-sm table-striped cache-metrics-table">
            <thead>
                <tr>
                    <th>Implementation</th>
                    <th>Hits</th>
                    <th>Misses</th>
                    <th>Backend calls</th>
                    <th>Cache entries</th>
                    <th>Retained memory</th>
                    <th>Hit ratio</th>
                    <th>Total response time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in GetRows(_result))
                {
                    <tr>
                        <td>@row.Label</td>
                        <td>@row.Hits</td>
                        <td>@row.Misses</td>
                        <td>@row.BackendCalls</td>
                        <td>@row.CacheEntries</td>
                        <td>@FormatBytes(row.RetainedBytes)</td>
                        <td>@FormatPercent(row.HitRatioPercent)</td>
                        <td>@FormatMilliseconds(row.ElapsedMilliseconds)</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private int _totalRequests = 1200;
    private int _concurrentWorkers = 32;
    private int _keySpace = 50;
    private int _payloadKilobytes = 32;
    private bool _isRunning;
    private string? _error;
    private CachingComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Cache Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_totalRequests, _concurrentWorkers, _keySpace, _payloadKilobytes);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static IEnumerable<CachingRunResult> GetRows(CachingComparisonResult result)
    {
        yield return result.Bad;
        yield return result.Practice;
        yield return result.Refactored;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes:N0} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024d:N1} KB";
        }

        return $"{bytes / (1024d * 1024d):N2} MB";
    }

    private static string FormatMilliseconds(double milliseconds)
    {
        return $"{milliseconds:N1} ms";
    }

    private static string FormatPercent(double value)
    {
        return $"{value:N1}%";
    }

    private static string FormatMemoryReduction(CachingComparisonResult result)
    {
        if (result.Bad.RetainedBytes <= 0)
        {
            return "n/a";
        }

        var reduction = 100 - (result.Refactored.RetainedBytes * 100.0 / result.Bad.RetainedBytes);
        return $"{reduction:N1}% less retained memory";
    }

    private static string FormatHitRatioImprovement(CachingComparisonResult result)
    {
        var delta = result.Refactored.HitRatioPercent - result.Bad.HitRatioPercent;
        return $"{delta:N1} percentage points";
    }

    private static string FormatSpeedup(CachingComparisonResult result)
    {
        if (result.Refactored.ElapsedMilliseconds <= 0.1)
        {
            return "n/a";
        }

        var speedup = result.Bad.ElapsedMilliseconds / result.Refactored.ElapsedMilliseconds;
        return $"{speedup:N1}x faster";
    }
}
