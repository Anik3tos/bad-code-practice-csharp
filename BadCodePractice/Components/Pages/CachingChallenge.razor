@page "/caching-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.CachingChallenge
@inject CachingChallengeRunner Runner

<PageTitle>Caching Challenge</PageTitle>

<header class="challenge-header">
    <div class="challenge-header-content">
        <h1 data-icon="💾">Caching Challenge</h1>
        <p class="lead">
            Fix caching anti-patterns that lead to memory exhaustion, poor hit rates, and thundering herd problems.
            Start with <code>PracticeCachingChallengeService.cs</code> and refactor until it matches <code>RefactoredCachingChallengeService.cs</code>.
        </p>
    </div>
</header>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="requests">Total requests</label>
        <input id="requests" type="number" class="form-control" min="100" max="5000" @bind="_totalRequests" />

        <label for="workers" class="mt-3">Concurrent workers</label>
        <input id="workers" type="number" class="form-control" min="4" max="128" @bind="_concurrentWorkers" />

        <label for="keyspace" class="mt-3">Key space size</label>
        <input id="keyspace" type="number" class="form-control" min="5" max="500" @bind="_keySpace" />

        <label for="payload" class="mt-3">Payload size (KB)</label>
        <input id="payload" type="number" class="form-control" min="4" max="256" @bind="_payloadKilobytes" />

        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-info">
        <p class="challenge-info-title">Anti-patterns to find and fix</p>
        <ul>
            <li><strong>Unbounded growth:</strong> Cache grows indefinitely without eviction, consuming all memory.</li>
            <li><strong>Missing TTL:</strong> No expiration policy means stale data and memory leaks.</li>
            <li><strong>Cache stampede:</strong> Multiple concurrent misses hit the backend simultaneously for the same key.</li>
            <li><strong>No size limits:</strong> Individual entries can be arbitrarily large without constraints.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="challenge-results">
        <h2>Results</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Memory retained:</strong> @FormatBytes(_result.Bad.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Bad.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Memory retained:</strong> @FormatBytes(_result.Practice.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Practice.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Memory retained:</strong> @FormatBytes(_result.Refactored.RetainedBytes)</p>
                <p><strong>Hit ratio:</strong> @FormatPercent(_result.Refactored.HitRatioPercent)</p>
                <p><strong>Response time:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>

        <div class="challenge-summary">
            <p><strong>Practice memory reduction:</strong> @FormatMemoryReduction(_result.Bad, _result.Practice)</p>
            <p><strong>Practice hit ratio improvement:</strong> @FormatHitRatioImprovement(_result.Bad, _result.Practice)</p>
            <p><strong>Practice speedup:</strong> @FormatSpeedup(_result.Bad, _result.Practice)</p>
            <p><strong>AI refactored memory reduction:</strong> @FormatMemoryReduction(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored hit ratio improvement:</strong> @FormatHitRatioImprovement(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored speedup:</strong> @FormatSpeedup(_result.Bad, _result.Refactored)</p>
        </div>

        <div class="challenge-table">
            <h3>Detailed Metrics</h3>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Implementation</th>
                        <th>Hits</th>
                        <th>Misses</th>
                        <th>Backend calls</th>
                        <th>Cache entries</th>
                        <th>Memory</th>
                        <th>Hit ratio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in GetRows(_result))
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td>@row.Hits</td>
                            <td>@row.Misses</td>
                            <td>@row.BackendCalls</td>
                            <td>@row.CacheEntries</td>
                            <td>@FormatBytes(row.RetainedBytes)</td>
                            <td>@FormatPercent(row.HitRatioPercent)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private int _totalRequests = 1200;
    private int _concurrentWorkers = 32;
    private int _keySpace = 50;
    private int _payloadKilobytes = 32;
    private bool _isRunning;
    private string? _error;
    private CachingComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_totalRequests, _concurrentWorkers, _keySpace, _payloadKilobytes);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static IEnumerable<CachingRunResult> GetRows(CachingComparisonResult result)
    {
        yield return result.Bad;
        yield return result.Practice;
        yield return result.Refactored;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes:N0} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024d:N1} KB";
        return $"{bytes / (1024d * 1024d):N2} MB";
    }

    private static string FormatMilliseconds(double ms) => $"{ms:N1} ms";
    private static string FormatPercent(double value) => $"{value:N1}%";

    private static string FormatMemoryReduction(CachingRunResult baseline, CachingRunResult candidate)
    {
        if (baseline.RetainedBytes <= 0) return "n/a";
        var reduction = 100 - (candidate.RetainedBytes * 100.0 / baseline.RetainedBytes);
        return $"{reduction:N1}% less memory";
    }

    private static string FormatHitRatioImprovement(CachingRunResult baseline, CachingRunResult candidate)
    {
        var delta = candidate.HitRatioPercent - baseline.HitRatioPercent;
        return $"{delta:N1} percentage points";
    }

    private static string FormatSpeedup(CachingRunResult baseline, CachingRunResult candidate)
    {
        if (candidate.ElapsedMilliseconds <= 0.1) return "n/a";
        var speedup = baseline.ElapsedMilliseconds / candidate.ElapsedMilliseconds;
        return $"{speedup:N1}x faster";
    }
}
