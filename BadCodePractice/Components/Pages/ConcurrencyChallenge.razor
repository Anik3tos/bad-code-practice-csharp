@page "/concurrency-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.ConcurrencyChallenge
@inject ConcurrencyChallengeRunner Runner

<PageTitle>Concurrency Challenge</PageTitle>

<h1>Concurrency Race Condition Lab</h1>

<p class="lead">
    Practice spotting and fixing shared mutable state issues in multi-threaded code.
    Start with <code>Features/ConcurrencyChallenge/PracticeConcurrencyService.cs</code>, which starts from the same
    implementation as <code>Features/ConcurrencyChallenge/BadConcurrencyService.cs</code>, then refactor it until it behaves
    like <code>Features/ConcurrencyChallenge/RefactoredConcurrencyService.cs</code>.
</p>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="itemCount">Concurrent Operations</label>
        <select id="itemCount" class="form-select" @bind="_itemCount">
            <option value="100">100 (May not always race)</option>
            <option value="1000">1,000</option>
            <option value="10000">10,000 (Recommended)</option>
            <option value="50000">50,000</option>
        </select>
        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-smells">
        <p class="mb-1 fw-semibold">What to find in the bad version:</p>
        <ul class="mb-0">
            <li>Shared mutable state updated concurrently without synchronization.</li>
            <li>Lost updates where multiple threads read the same value before computing the next increment.</li>
            <li>Nondeterministic final totals instead of the exact expected number.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="mt-4">
        <h2>Run Result for @(_result.ExpectedCount.ToString("N0")) Operations</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad @(_result.Bad.IsCorrect ? "" : "border-danger")">
                <h3>@_result.Bad.Label</h3>
                <p>
                    <strong>Expected:</strong> @(_result.Bad.ExpectedCount.ToString("N0"))
                </p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Bad.IsCorrect ? "text-success" : "text-danger fw-bold")">
                        @(_result.Bad.ActualCount.ToString("N0"))
                    </span>
                </p>
                <p>
                    <strong>Missed Updates:</strong> @(_result.Bad.Difference.ToString("N0"))
                </p>
                <p>
                    <strong>Elapsed:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)
                </p>
            </article>

            <article class="challenge-card challenge-card-practice @(_result.Practice.IsCorrect ? "" : "border-danger")">
                <h3>@_result.Practice.Label</h3>
                <p>
                    <strong>Expected:</strong> @(_result.Practice.ExpectedCount.ToString("N0"))
                </p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Practice.IsCorrect ? "text-success" : "text-danger fw-bold")">
                        @(_result.Practice.ActualCount.ToString("N0"))
                    </span>
                </p>
                <p>
                    <strong>Missed Updates:</strong> @(_result.Practice.Difference.ToString("N0"))
                </p>
                <p>
                    <strong>Elapsed:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)
                </p>
            </article>

            <article class="challenge-card challenge-card-good @(_result.Refactored.IsCorrect ? "border-success" : "")">
                <h3>@_result.Refactored.Label</h3>
                <p>
                    <strong>Expected:</strong> @(_result.Refactored.ExpectedCount.ToString("N0"))
                </p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Refactored.IsCorrect ? "text-success fw-bold" : "text-danger")">
                        @(_result.Refactored.ActualCount.ToString("N0"))
                    </span>
                </p>
                <p>
                    <strong>Missed Updates:</strong> @(_result.Refactored.Difference.ToString("N0"))
                </p>
                <p>
                    <strong>Elapsed:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)
                </p>
            </article>
        </div>
    </section>
}

@code {
    private int _itemCount = 10000;
    private bool _isRunning;
    private string? _error;
    private ConcurrencyChallengeComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Bad vs Practice vs Refactored";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_itemCount);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static string FormatMilliseconds(double value)
    {
        return $"{value:N1} ms";
    }

}
