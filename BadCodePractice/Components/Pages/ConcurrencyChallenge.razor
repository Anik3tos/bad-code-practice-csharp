@page "/concurrency-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.ConcurrencyChallenge
@inject ConcurrencyChallengeRunner Runner

<PageTitle>Concurrency Challenge</PageTitle>

<header class="challenge-header">
    <div class="challenge-header-content">
        <h1 data-icon="🔀">Concurrency Challenge</h1>
        <p class="lead">
            Identify and fix race conditions caused by unsynchronized access to shared mutable state.
            Start with <code>PracticeConcurrencyService.cs</code> and refactor until all operations complete correctly.
        </p>
    </div>
</header>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="itemCount">Concurrent Operations</label>
        <select id="itemCount" class="form-select" @bind="_itemCount">
            <option value="100">100 (May not race)</option>
            <option value="1000">1,000</option>
            <option value="10000">10,000 (Recommended)</option>
            <option value="50000">50,000</option>
        </select>
        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-info">
        <p class="challenge-info-title">Race condition patterns to fix</p>
        <ul>
            <li><strong>Lost updates:</strong> Multiple threads read-modify-write without synchronization, overwriting each other.</li>
            <li><strong>Non-atomic operations:</strong> <code>count++</code> is not atomic—read, increment, write are separate steps.</li>
            <li><strong>Incorrect locking:</strong> Locking on the wrong object or too narrow a scope.</li>
            <li><strong>Missing memory barriers:</strong> Without volatile or locks, thread caches may not see updates.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="challenge-results">
        <h2>Results for @_result.ExpectedCount.ToString("N0") Operations</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad @(_result.Bad.IsCorrect ? "" : "border-danger")">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Expected:</strong> @_result.Bad.ExpectedCount.ToString("N0")</p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Bad.IsCorrect ? "text-success" : "text-danger fw-bold")">
                        @_result.Bad.ActualCount.ToString("N0")
                    </span>
                </p>
                <p><strong>Missed updates:</strong> @_result.Bad.Difference.ToString("N0")</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-practice @(_result.Practice.IsCorrect ? "" : "border-danger")">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Expected:</strong> @_result.Practice.ExpectedCount.ToString("N0")</p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Practice.IsCorrect ? "text-success" : "text-danger fw-bold")">
                        @_result.Practice.ActualCount.ToString("N0")
                    </span>
                </p>
                <p><strong>Missed updates:</strong> @_result.Practice.Difference.ToString("N0")</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good @(_result.Refactored.IsCorrect ? "border-success" : "")">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Expected:</strong> @_result.Refactored.ExpectedCount.ToString("N0")</p>
                <p>
                    <strong>Actual:</strong>
                    <span class="@(_result.Refactored.IsCorrect ? "text-success fw-bold" : "text-danger")">
                        @_result.Refactored.ActualCount.ToString("N0")
                    </span>
                </p>
                <p><strong>Missed updates:</strong> @_result.Refactored.Difference.ToString("N0")</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>
    </section>
}

@code {
    private int _itemCount = 10000;
    private bool _isRunning;
    private string? _error;
    private ConcurrencyChallengeComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_itemCount);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static string FormatMilliseconds(double value) => $"{value:N1} ms";
}
