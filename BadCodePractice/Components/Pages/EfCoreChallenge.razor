@page "/ef-core-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Data
@using BadCodePractice.Features.EfCoreChallenge
@inject EfCoreChallengeRunner Runner

<PageTitle>EF Core Challenge</PageTitle>

<h1>EF Core Bad Code Lab</h1>

<p class="lead">
    Practice spotting and fixing query anti-patterns.
    Start with <code>Features/EfCoreChallenge/BadOrderReportService.cs</code>, then refactor it until it behaves
    like <code>Features/EfCoreChallenge/RefactoredOrderReportService.cs</code>.
</p>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="city">City</label>
        <select id="city" class="form-select" @bind="_city">
            @foreach (var city in ChallengeSeeder.Cities)
            {
                <option value="@city">@city</option>
            }
        </select>
        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-smells">
        <p class="mb-1 fw-semibold">What to find in the bad version:</p>
        <ul class="mb-0">
            <li>Loads far more rows than needed</li>
            <li>Filters in memory instead of SQL</li>
            <li>N+1 queries for shipments</li>
            <li>No <code>AsNoTracking()</code> for read-only query</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="mt-4">
        <h2>Run Result for @(_result.City)</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Rows:</strong> @_result.Bad.Rows</p>
                <p><strong>SQL Commands:</strong> @_result.Bad.QueryCount</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Rows:</strong> @_result.Refactored.Rows</p>
                <p><strong>SQL Commands:</strong> @_result.Refactored.QueryCount</p>
                <p><strong>Elapsed:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
            </article>
        </div>

        <div class="challenge-summary mt-3">
            <p class="mb-1">
                <strong>Query reduction:</strong> @FormatQueryReduction(_result)
            </p>
            <p class="mb-0">
                <strong>Speedup:</strong> @FormatSpeedup(_result)
            </p>
        </div>

        <h3 class="mt-4">Top 5 Orders (Refactored)</h3>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Order Id</th>
                    <th>Customer</th>
                    <th>City</th>
                    <th>Total</th>
                    <th>Shipped</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _result.Refactored.TopRows)
                {
                    <tr>
                        <td>@row.OrderId</td>
                        <td>@row.Customer</td>
                        <td>@row.City</td>
                        <td>@row.Total.ToString("C")</td>
                        <td>@(row.Shipped?.ToString("yyyy-MM-dd") ?? "Pending")</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private string _city = ChallengeSeeder.Cities[0];
    private bool _isRunning;
    private string? _error;
    private ChallengeComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Bad vs Refactored";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_city);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static string FormatMilliseconds(double value)
    {
        return $"{value:N1} ms";
    }

    private static string FormatQueryReduction(ChallengeComparisonResult result)
    {
        if (result.Bad.QueryCount == 0)
        {
            return "n/a";
        }

        var reduction = 100 - (result.Refactored.QueryCount * 100.0 / result.Bad.QueryCount);
        return $"{reduction:N1}% fewer SQL commands";
    }

    private static string FormatSpeedup(ChallengeComparisonResult result)
    {
        if (result.Refactored.ElapsedMilliseconds <= 0.1)
        {
            return "n/a";
        }

        var speedup = result.Bad.ElapsedMilliseconds / result.Refactored.ElapsedMilliseconds;
        return $"{speedup:N1}x faster";
    }
}
