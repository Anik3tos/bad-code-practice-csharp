@page "/serialization-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.SerializationChallenge
@inject SerializationChallengeRunner Runner

<PageTitle>Serialization Challenge</PageTitle>

<header class="challenge-header">
    <div class="challenge-header-content">
        <h1 data-icon="🧾">Serialization Challenge</h1>
        <p class="lead">
            Optimize JSON serialization to reduce allocations, eliminate reflection overhead, and improve throughput.
            Start with <code>PracticeSerializationService.cs</code> and refactor until it matches <code>RefactoredSerializationService.cs</code>.
        </p>
    </div>
</header>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="totalRequests">Total requests</label>
        <input id="totalRequests" type="number" class="form-control" min="100" max="5000" @bind="_totalRequests" />

        <label for="workers" class="mt-3">Concurrent workers</label>
        <input id="workers" type="number" class="form-control" min="4" max="128" @bind="_concurrentWorkers" />

        <label for="extraFieldLength" class="mt-3">Extra field size (chars)</label>
        <input id="extraFieldLength" type="number" class="form-control" min="64" max="4096" @bind="_extraFieldLength" />

        <button class="btn btn-primary mt-3" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
    </div>

    <div class="challenge-info">
        <p class="challenge-info-title">Serialization anti-patterns to fix</p>
        <ul>
            <li><strong>Reflection overhead:</strong> Default JSON serialization uses reflection on every call in hot paths.</li>
            <li><strong>Synchronous serialization:</strong> Blocking calls on request threads instead of async streaming.</li>
            <li><strong>Missing source generators:</strong> No <code>[JsonSerializable]</code> for AOT-friendly compile-time metadata.</li>
            <li><strong>Over-serialization:</strong> Serializing fields that aren't needed by the consumer.</li>
            <li><strong>No pooling:</strong> Not reusing buffers or streams for repeated operations.</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="challenge-results">
        <h2>Results</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Allocations:</strong> @FormatBytes(_result.Bad.AllocatedBytes)</p>
                <p><strong>Serialization time:</strong> @FormatMilliseconds(_result.Bad.ElapsedMilliseconds)</p>
                <p><strong>Reflection misses:</strong> @_result.Bad.ReflectionCacheMisses.ToString("N0")</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Allocations:</strong> @FormatBytes(_result.Practice.AllocatedBytes)</p>
                <p><strong>Serialization time:</strong> @FormatMilliseconds(_result.Practice.ElapsedMilliseconds)</p>
                <p><strong>Reflection misses:</strong> @_result.Practice.ReflectionCacheMisses.ToString("N0")</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Allocations:</strong> @FormatBytes(_result.Refactored.AllocatedBytes)</p>
                <p><strong>Serialization time:</strong> @FormatMilliseconds(_result.Refactored.ElapsedMilliseconds)</p>
                <p><strong>Reflection misses:</strong> @_result.Refactored.ReflectionCacheMisses.ToString("N0")</p>
            </article>
        </div>

        <div class="challenge-summary">
            <p><strong>Practice allocation reduction:</strong> @FormatAllocationReduction(_result.Bad, _result.Practice)</p>
            <p><strong>Practice speedup:</strong> @FormatSpeedup(_result.Bad, _result.Practice)</p>
            <p><strong>Practice reflection miss reduction:</strong> @FormatMissReduction(_result.Bad, _result.Practice)</p>
            <p><strong>AI refactored allocation reduction:</strong> @FormatAllocationReduction(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored speedup:</strong> @FormatSpeedup(_result.Bad, _result.Refactored)</p>
            <p><strong>AI refactored reflection miss reduction:</strong> @FormatMissReduction(_result.Bad, _result.Refactored)</p>
        </div>

        <div class="challenge-table">
            <h3>Detailed Metrics</h3>
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Implementation</th>
                        <th>Requests</th>
                        <th>Allocations</th>
                        <th>Time</th>
                        <th>Reflection misses</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in GetRows(_result))
                    {
                        <tr>
                            <td>@row.Label</td>
                            <td>@row.TotalRequests.ToString("N0")</td>
                            <td>@FormatBytes(row.AllocatedBytes)</td>
                            <td>@FormatMilliseconds(row.ElapsedMilliseconds)</td>
                            <td>@row.ReflectionCacheMisses.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private int _totalRequests = 1500;
    private int _concurrentWorkers = 32;
    private int _extraFieldLength = 600;
    private bool _isRunning;
    private string? _error;
    private SerializationComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;

        try
        {
            _result = await Runner.RunAsync(_totalRequests, _concurrentWorkers, _extraFieldLength);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private static IEnumerable<SerializationScenarioResult> GetRows(SerializationComparisonResult result)
    {
        yield return result.Bad;
        yield return result.Practice;
        yield return result.Refactored;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes:N0} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024d:N1} KB";
        return $"{bytes / (1024d * 1024d):N2} MB";
    }

    private static string FormatMilliseconds(double value) => $"{value:N1} ms";

    private static string FormatAllocationReduction(SerializationScenarioResult baseline, SerializationScenarioResult candidate)
    {
        if (baseline.AllocatedBytes <= 0) return "n/a";
        var reduction = 100 - candidate.AllocatedBytes * 100.0 / baseline.AllocatedBytes;
        return $"{reduction:N1}% less memory";
    }

    private static string FormatSpeedup(SerializationScenarioResult baseline, SerializationScenarioResult candidate)
    {
        if (candidate.ElapsedMilliseconds <= 0.1) return "n/a";
        var speedup = baseline.ElapsedMilliseconds / candidate.ElapsedMilliseconds;
        return $"{speedup:N1}x faster";
    }

    private static string FormatMissReduction(SerializationScenarioResult baseline, SerializationScenarioResult candidate)
    {
        if (baseline.ReflectionCacheMisses <= 0) return "n/a";
        var reduction = 100 - candidate.ReflectionCacheMisses * 100.0 / baseline.ReflectionCacheMisses;
        return $"{reduction:N1}% fewer misses";
    }
}
