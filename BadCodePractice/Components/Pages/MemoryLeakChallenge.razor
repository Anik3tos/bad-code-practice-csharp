@page "/memory-leak-challenge"
@rendermode InteractiveServer
@using BadCodePractice.Features.MemoryLeakChallenge
@inject MemoryLeakChallengeRunner Runner

<PageTitle>Memory Leak Challenge</PageTitle>

<h1>Memory Leak Challenge</h1>

<p class="lead">
    Start with <code>Features/MemoryLeakChallenge/PracticeMemoryLeakService.cs</code>.
    It intentionally matches the bad implementation so you can refactor and compare retained memory.
</p>

<section class="challenge-panel">
    <div class="challenge-controls">
        <label for="iterations">Iterations</label>
        <input id="iterations" type="number" class="form-control" min="10" max="400" @bind="_iterations" />

        <label for="payload" class="mt-3">Payload (KB)</label>
        <input id="payload" type="number" class="form-control" min="16" max="512" @bind="_payloadKilobytes" />

        <button class="btn btn-primary mt-3 me-2" @onclick="RunScenarioAsync" disabled="@_isRunning">
            @_buttonText
        </button>
        <button class="btn btn-outline-secondary mt-3" @onclick="ResetStateAsync" disabled="@_isRunning">
            Reset leaked state
        </button>
    </div>

    <div class="challenge-smells">
        <p class="mb-1 fw-semibold">Most common memory leak causes in .NET apps:</p>
        <ul class="mb-0">
            <li>Long-lived static references and singleton state</li>
            <li>Event subscriptions not unsubscribed</li>
            <li>Timers and background workers not disposed</li>
            <li>Unbounded caches or collections</li>
            <li>Closures capturing large objects</li>
            <li>Forgotten <code>IDisposable</code> cleanup paths</li>
        </ul>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-info mt-3" role="status">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3" role="alert">@_error</div>
}

@if (_result is not null)
{
    <section class="mt-4">
        <h2>Retained Memory Summary</h2>

        <div class="challenge-grid">
            <article class="challenge-card challenge-card-bad">
                <h3>@_result.Bad.Label</h3>
                <p><strong>Total Retained:</strong> @FormatBytes(_result.Bad.TotalRetainedBytes)</p>
            </article>

            <article class="challenge-card challenge-card-practice">
                <h3>@_result.Practice.Label</h3>
                <p><strong>Total Retained:</strong> @FormatBytes(_result.Practice.TotalRetainedBytes)</p>
            </article>

            <article class="challenge-card challenge-card-good">
                <h3>@_result.Refactored.Label</h3>
                <p><strong>Total Retained:</strong> @FormatBytes(_result.Refactored.TotalRetainedBytes)</p>
            </article>
        </div>

        <div class="challenge-summary mt-3">
            <p class="mb-1">
                <strong>Retained memory reduction:</strong> @FormatReduction(_result)
            </p>
            <p class="mb-0">
                <strong>Improvement ratio:</strong> @FormatImprovement(_result)
            </p>
        </div>

        <h3 class="mt-4">Per Cause Breakdown</h3>
        <table class="table table-sm table-striped memory-table">
            <thead>
                <tr>
                    <th>Cause</th>
                    <th>Bad</th>
                    <th>Practice</th>
                    <th>Refactored</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < _result.Bad.Causes.Count; i++)
                {
                    var bad = _result.Bad.Causes[i];
                    var practice = _result.Practice.Causes[i];
                    var refactored = _result.Refactored.Causes[i];

                    <tr>
                        <td>@bad.Cause</td>
                        <td>@FormatBytes(bad.RetainedBytes)</td>
                        <td>@FormatBytes(practice.RetainedBytes)</td>
                        <td>@FormatBytes(refactored.RetainedBytes)</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private int _iterations = 120;
    private int _payloadKilobytes = 64;
    private bool _isRunning;
    private string? _error;
    private string? _message;
    private MemoryLeakComparisonResult? _result;

    private string _buttonText => _isRunning ? "Running..." : "Run Memory Leak Comparison";

    private async Task RunScenarioAsync()
    {
        _isRunning = true;
        _error = null;
        _message = null;

        try
        {
            _result = await Runner.RunAsync(_iterations, _payloadKilobytes);
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private Task ResetStateAsync()
    {
        Runner.ResetLeakedState();
        _message = "Leaked state reset completed.";
        _error = null;
        return Task.CompletedTask;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes:N0} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024d:N1} KB";
        }

        return $"{bytes / (1024d * 1024d):N2} MB";
    }

    private static string FormatReduction(MemoryLeakComparisonResult result)
    {
        if (result.Bad.TotalRetainedBytes <= 0)
        {
            return "n/a";
        }

        var reduction = 100 - (result.Refactored.TotalRetainedBytes * 100.0 / result.Bad.TotalRetainedBytes);
        return $"{reduction:N1}% less retained memory";
    }

    private static string FormatImprovement(MemoryLeakComparisonResult result)
    {
        if (result.Refactored.TotalRetainedBytes <= 0)
        {
            return "n/a";
        }

        var ratio = result.Bad.TotalRetainedBytes / (double)result.Refactored.TotalRetainedBytes;
        return $"{ratio:N1}x better retention profile";
    }
}
